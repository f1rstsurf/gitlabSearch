# Secure server-side default token used when UI token field is empty.
# Put your real token only in local `.env` (never commit it).
GITLAB_TOKEN=glpat-REPLACE_ME

# Default group used when UI group field is empty.
GITLAB_GROUP_ID=XXXXXX

# Optional (default: https://gitlab.com/api/v4)
# GITLAB_BASE_URL=https://gitlab.com/api/v4

# Optional (derived from GITLAB_BASE_URL by removing /api/v4)
# GITLAB_WEB_URL=https://gitlab.com

# Optional (default: 8080)
# PORT=8080
